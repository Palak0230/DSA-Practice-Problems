class Solution {
    public String[] createGrid(int m, int n) {
        char[][] grid= new char[m][n];
        for(char[] row:grid){
            Arrays.fill(row,'#');
        }
        for(int i=0; i<n; i++) grid[0][i]='.';
        for(int k=0; k<m; k++) grid[k][n-1]='.';
        String[] ans=new String[m];
        for(int j=0; j<m;j++){
            ans[j]=new String(grid[j]);
        }
        return ans;
    }
}
